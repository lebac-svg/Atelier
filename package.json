{
  "name": "atelier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b && tsc -p packages/web/tsconfig.json",
    "build": "tsc -b",
    "build:web": "pnpm --filter @atelier/web build",
    "demo:p2": "tsx packages/server/scripts/demo-p2.ts",
    "demo:p3": "tsx packages/server/scripts/demo-p3.ts",
    "demo:p4": "tsx packages/server/scripts/demo-p4.ts",
    "demo:p5": "tsx packages/server/scripts/demo-p5.ts",
    "build:cli": "pnpm build:web && pnpm --filter atelier-mcp build"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "tsx": "^4.19.0"
  },
  "description": "An AI architect for any MCP client — multi-typology houses on any lot, pluggable building-standard rule packs (TCVN, UK Approved Documents), live two-way browser editor, furnished 3D walkthrough, PDF/DXF/IFC documentation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lebac-svg/Atelier.git"
  },
  "homepage": "https://github.com/lebac-svg/Atelier#readme",
  "bugs": {
    "url": "https://github.com/lebac-svg/Atelier/issues"
  }
}
