{
  "name": "atelier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20.10" },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b && tsc -p packages/web/tsconfig.json",
    "build": "tsc -b",
    "build:web": "pnpm --filter @atelier/web build",
    "demo:p2": "tsx packages/server/scripts/demo-p2.ts",
    "demo:p3": "tsx packages/server/scripts/demo-p3.ts",
    "demo:p4": "tsx packages/server/scripts/demo-p4.ts"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "tsx": "^4.19.0"
  }
}
