{
  "mcpServers": {
    "haido": {
      "command": "haido",
      "args": [
        "serve"
      ]
    },
    "atelier": {
      "command": "node",
      "args": [
        "--import",
        "tsx",
        "packages/server/src/mcp.ts"
      ],
      "env": {
        "ATELIER_DIR": "sandbox/demo"
      }
    }
  }
}
